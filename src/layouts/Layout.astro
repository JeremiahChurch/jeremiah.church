---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Jeremiah Church',
  description = 'Technical founder. Currently building Comma Compliance.',
  canonical,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="generator" content={Astro.generator} />

    <!--
      hi. there is a flag on this site.
      start at /.well-known/security.txt and follow the breadcrumbs.
    -->
  </head>
  <body class="min-h-dvh flex flex-col">
    <header class="border-b border-[var(--color-rule)]">
      <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between text-sm">
        <a href="/" class="font-mono font-semibold no-underline tracking-tight">
          jeremiah.church
        </a>
        <ul class="flex gap-6 font-mono text-[var(--color-muted)]">
          <li><a href="/" class="no-underline hover:text-[var(--color-ink)]">home</a></li>
          <li><a href="/uses" class="no-underline hover:text-[var(--color-ink)]">uses</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl w-full mx-auto px-6 py-16">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-rule)] mt-24">
      <div class="max-w-3xl mx-auto px-6 py-8 flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between text-sm text-[var(--color-muted)] font-mono">
        <p>
          &copy; {new Date().getFullYear()} Jeremiah Church.
        </p>
        <ul class="flex gap-5">
          <li><a href="https://github.com/JeremiahChurch" rel="me" class="no-underline hover:text-[var(--color-ink)]">github</a></li>
          <li><a href="https://www.linkedin.com/in/jeremiahchurch/" rel="me" class="no-underline hover:text-[var(--color-ink)]">linkedin</a></li>
          <li><a href="mailto:hi@jeremiah.church" class="no-underline hover:text-[var(--color-ink)]">email</a></li>
        </ul>
      </div>
    </footer>
  </body>
</html>
